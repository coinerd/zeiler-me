{
  "name": "zeiler-me",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "rimraf public/sw.js public/sw.js.map public/workbox-*.js public/workbox-*.js.map public/fallback-*.js public/fallback-*.js.map public/worker-*.js public/worker-*.js.map public/swe-worker-*.js public/swe-worker-*.js.map .next",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "start-server-and-test start http://localhost:3000 \"pa11y http://localhost:3000 --standard WCAG2AA\"",
    "check-all": "npm run lint && npm run typecheck && npm run test && npm run format:check"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.5.19",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.320.0",
    "next": "^15.5.15",
    "next-themes": "^0.4.6",
    "react": "^18",
    "react-dom": "^18",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0",
    "tailwind-merge": "^2.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@next/bundle-analyzer": "^16.2.7",
    "@tailwindcss/typography": "^0.5.16",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "eslint-config-prettier": "^9.1.2",
    "glob": "^10.3.10",
    "pa11y": "^9.1.1",
    "postcss": "^8",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "rimraf": "^5.0.5",
    "start-server-and-test": "^3.0.9",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vitest": "^1.6.1"
  },
  "overrides": {
    "inflight": "npm:lru-cache@^7.14.1",
    "glob": "^10.3.10",
    "rimraf": "^5.0.5"
  },
  "allowScripts": {
    "@next/bundle-analyzer@16.2.7": true,
    "sharp@0.34.5": true,
    "start-server-and-test@3.0.9": true
  }
}
